public class Number2 {
    static void main(String[] args) {
        int [][] a = {
                {10, 20},
                {30, 40},
                {50, 60}
        };
        System.out.println("a[0][0]=" + a[0][0] + " a[0][1]=" + a[0][1] + "\n" +
                           "a[1][0]=" + a[1][0] + " a[1][1]=" + a[1][1] + "\n" +
                           "a[2][0]=" + a[2][0] + " a[2][1]=" + a[2][1]);
    }
}
